# Copy to services/api/.env and fill in real values locally.
# Never commit the actual .env file — it's excluded via .gitignore.

# --- Database ---
DATABASE_URL=

# --- Payment gateways ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=sandbox
GOOGLE_PAY_MERCHANT_ID=

# Amazon Payment Services (formerly PayFort) — get these from your APS
# merchant dashboard. APS_API_BASE_URL differs for sandbox vs production;
# confirm the current correct value there, don't guess.
APS_MERCHANT_IDENTIFIER=
APS_ACCESS_CODE=
APS_SHA_REQUEST_PHRASE=
APS_SHA_RESPONSE_PHRASE=
APS_API_BASE_URL=

# Add region-specific gateway credentials as they're approved (e.g. Mada)

# --- Notifications ---
SMS_PROVIDER_API_KEY=
EMAIL_PROVIDER_API_KEY=
PUSH_NOTIFICATION_SERVER_KEY=

# --- Translation ---
TRANSLATION_API_KEY=

# --- Tax / VAT (if a third-party service is selected, see Charter Section 1) ---
TAX_SERVICE_API_KEY=

# --- Auth ---
JWT_SECRET=
